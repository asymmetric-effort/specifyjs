#!/usr/bin/env bash
set -euo pipefail

echo "=== pre-commit: running linter and formatter ==="

cd "$(git rev-parse --show-toplevel)/core"

# TypeScript type check
echo "[1/2] TypeScript typecheck..."
npx tsc --noEmit
echo "  ✓ typecheck passed"

# Prettier format check
echo "[2/2] Prettier format check..."
npx prettier --check 'src/**/*.ts' 'tests/**/*.ts'
echo "  ✓ formatting passed"

echo "=== pre-commit: all checks passed ==="
